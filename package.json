{
  "name": "asciinun",
  "version": "0.1.0",
  "description": "AsciiNun",
  "author": {
    "name": "Jungwoo Nam",
    "email": "nunu3041@gmail.com",
    "url": "https://github.com/coloriz"
  },
  "bin": {
    "asciinun": "./bin/run.js"
  },
  "homepage": "https://github.com/coloriz/asciinun",
  "license": "MIT",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/coloriz/asciinun.git"
  },
  "files": [
    "/bin",
    "/dist",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "rimraf ./dist",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings 0 --report-unused-disable-directives",
    "lint:fix": "yarn lint --fix",
    "start": "yarn build && node ./dist/index.js"
  },
  "dependencies": {
    "@oclif/core": "^2",
    "@oclif/plugin-help": "^5",
    "@oclif/plugin-plugins": "^2.4.0",
    "asciidoctor": "^2.2.6"
  },
  "devDependencies": {
    "@oclif/test": "^2.3.10",
    "@types/chai": "^4.3.4",
    "@types/mocha": "^10.0.1",
    "@types/node": "^18.14.4",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "chai": "^4",
    "eslint": "^8.35.0",
    "eslint-config-oclif": "^4",
    "eslint-config-oclif-typescript": "^1.0.3",
    "eslint-config-prettier": "^8.6.0",
    "eslint-import-resolver-typescript": "^3.5.3",
    "eslint-plugin-import": "^2.27.5",
    "mocha": "^10",
    "oclif": "^3",
    "prettier": "^2.8.4",
    "rimraf": "^4.3.0",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.2",
    "typescript": "^4.9.5"
  },
  "oclif": {
    "bin": "asciinun",
    "dirname": "asciinun",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " ",
    "topics": {
      "hello": {
        "description": "Say hello to the world and others"
      }
    }
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "bugs": {
    "url": "https://github.com/coloriz/asciinun/issues"
  },
  "keywords": [
    "oclif"
  ],
  "types": "dist/index.d.ts"
}
